# ===== LM Studio (OpenAI-compatible) =====
# From containers we reach the Windows host via host.docker.internal
LM_BASE_URL=http://host.docker.internal:1234/v1
LM_API_KEY=lm-studio
LM_MODEL=auto

# ===== STT (faster-whisper) =====
# model: tiny | base | small | medium | large-v3
WHISPER_MODEL=medium
# device: auto | cuda | cpu
WHISPER_DEVICE=auto
# compute: auto | float16 (gpu) | int8 (cpu)
WHISPER_COMPUTE_TYPE=auto
# language: ru | en | (empty = autodetect)
WHISPER_LANGUAGE=ru

# ===== GPU =====
GPU_COUNT=all

# ===== Host ports =====
PORT_STT=8100
PORT_TTS=8101
PORT_MOCK=8102
PORT_GATEWAY=8103

# ===== TTS =====
PIPER_VOICE=/voices/ru_RU-dmitri-medium.onnx

# ===== Later: real 1C endpoint instead of mock =====
# STOCK_API_URL=http://mock-api:8000/api/stock

# ===== 1C MCP Toolkit (https://github.com/ROCTUP/1c-mcp-toolkit) =====
# Встроенный HTTP-сервер обработки MCP_Toolkit.epf в 1С:ERP слушает :6003.
# Из контейнеров ходим через host.docker.internal.
ONEC_BASE_URL=http://host.docker.internal:6003/api
ONEC_CHANNEL=
ONEC_TIMEOUT=30

# Источник остатков: "1c" (MCP Toolkit) или "mock" (mock-api).
# При "1c" и ошибке — откат на mock, если STOCK_FALLBACK_TO_MOCK=true.
STOCK_BACKEND=1c
STOCK_FALLBACK_TO_MOCK=true
STOCK_API_URL=http://mock-api:8000/api/stock
